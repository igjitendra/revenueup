---
import Base from '../../layouts/Base.astro';
import { legalDocs } from '../../data/legal';

export function getStaticPaths() {
  return Object.entries(legalDocs).map(([slug, doc]) => ({
    params: { slug },
    props: { doc }
  }));
}

const { doc } = Astro.props;
---

<Base title={`${doc.title} — RevenueUp`}>
  <section class="page-hero legal-hero">
    <div class="container">
      <span class="eyebrow">LEGAL</span>
      <h1>{doc.title}</h1>
      <p>Last updated: {doc.updated}</p>
    </div>
  </section>

  <section class="section">
    <article class="legal-copy">
      <div class="notice">
        Template copy for review. Insert the registered legal entity, jurisdiction and counsel-approved terms before launch.
      </div>

      {doc.sections.map((section, index) => (
        <section>
          <span>0{index + 1}</span>
          <div>
            <h2>{section[0]}</h2>
            <p>{section[1]}</p>
          </div>
        </section>
      ))}
    </article>
  </section>
</Base>
