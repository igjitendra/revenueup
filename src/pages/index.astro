---
import Base from '../layouts/Base.astro'; import SectionHead from '../components/SectionHead.astro'; import ServiceGrid from '../components/ServiceGrid.astro'; import CTA from '../components/CTA.astro'; import {faqs} from '../data/site';
---
<Base>
<section class="hero"><div class="hero-noise"></div><div class="container hero-grid"><div class="hero-copy"><span class="eyebrow light">INDEPENDENT GROWTH STUDIO · INDIA</span><h1>Build a brand<br/>people <em>notice.</em><br/>Grow a business<br/>that <em>performs.</em></h1><p>Performance marketing, personal branding and conversion-first digital experiences for ambitious founders and businesses.</p><div class="hero-actions"><a class="button button-light" href="/contact">Start a project <span>↗</span></a><a class="text-link light" href="/work">See our approach <span>↓</span></a></div><div class="trust-row"><span><b>6+</b> Years of experience</span><span><b>360°</b> Growth capability</span><span><b>01</b> Accountable partner</span></div></div><div class="hero-visual" aria-hidden="true"><div class="visual-card card-a"><small>GROWTH SIGNAL</small><strong>+184%</strong><span>Qualified engagement</span><svg viewBox="0 0 240 80"><path d="M0 68 C35 64 38 49 70 55 S118 47 142 34 S181 41 240 8"/></svg></div><div class="visual-card card-b"><div class="mini-logo">R</div><span>RevenueUp</span><small>strategy · creative · technology</small></div><div class="visual-ring"><i></i></div><div class="spark">✦</div></div></div></section>
<section class="logo-strip"><div class="container"><span>BUILT FOR</span><b>COACHES</b><b>CONSULTANTS</b><b>CREATORS</b><b>STARTUPS</b><b>D2C BRANDS</b></div></section>
<section class="section"><div class="container"><SectionHead eyebrow="WHAT WE DO" title="One growth partner.<br/><em>Every critical capability.</em>" copy="We connect strategy, creative, media and technology—so your growth engine works as one system."/><ServiceGrid /></div></section>
<section class="section dark-section"><div class="container process-grid"><div><span class="eyebrow light">OUR PROCESS</span><h2>Clarity before<br/><em>complexity.</em></h2><p>A focused process keeps the work sharp, the communication clear and every decision tied to a business outcome.</p><a class="button button-outline" href="/about">How we work <span>↗</span></a></div><div class="steps">{[['01','Discover','Goals, audience, offer and constraints.'],['02','Design','Strategy, message and experience system.'],['03','Deploy','Launch, measure and optimize quickly.'],['04','Scale','Double down on what produces signal.']].map(x=><div class="step reveal"><b>{x[0]}</b><h3>{x[1]}</h3><p>{x[2]}</p><span>↗</span></div>)}</div></div></section>
<section class="section"><div class="container"><SectionHead eyebrow="SELECTED OUTCOMES" title="Proof should be <em>specific.</em>" copy="Representative engagement formats. Replace these with verified client data before publishing."/><div class="case-grid"><article class="case case-purple reveal"><div><span>PERSONAL BRAND · CONTENT</span><h3>Authority engine for an expert-led business</h3></div><div class="metric"><b>3.1×</b><span>engagement quality</span></div></article><article class="case case-orange reveal"><div><span>PAID MEDIA · FUNNEL</span><h3>Lead acquisition system for a service business</h3></div><div class="metric"><b>−42%</b><span>cost per qualified lead</span></div></article></div><p class="disclaimer">Illustrative placeholders—not published client claims.</p></div></section>
<section class="section soft"><div class="container"><SectionHead center eyebrow="WHY REVENUEUP" title="Senior thinking.<br/><em>Focused execution.</em>"/><div class="value-grid">{[['No vanity metrics','We optimize for qualified conversations, conversion and commercial signal.'],['Built for speed','Lean collaboration and shorter feedback loops keep good ideas moving.'],['Radical visibility','Clear scope, shared access and reporting you can actually understand.'],['One connected system','Brand, content, paid media and web decisions reinforce each other.']].map((x,i)=><div class="value reveal"><span>0{i+1}</span><h3>{x[0]}</h3><p>{x[1]}</p></div>)}</div></div></section>
<section class="section"><div class="container faq-grid"><div><span class="eyebrow">COMMON QUESTIONS</span><h2>Good questions<br/>lead to <em>better work.</em></h2></div><div class="faqs">{faqs.map((f,i)=><details open={i===0}><summary>{f[0]}<span>+</span></summary><p>{f[1]}</p></details>)}</div></div></section><CTA />
</Base>
