---
import Base from '../layouts/Base.astro';import {contact} from '../data/site';
---
<Base title="Contact — RevenueUp"><section class="contact-page"><div class="container contact-grid"><div><span class="eyebrow light">START A CONVERSATION</span><h1>Tell us what<br/>you want to <em>grow.</em></h1><p>Share your goal, current challenge and timeline. We’ll reply with the most useful next step.</p><div class="contact-details"><a href={'mailto:'+contact.email}><small>EMAIL</small>{contact.email}</a><a href={'tel:'+contact.phone.replace(/ /g,'')}><small>PHONE / WHATSAPP</small>{contact.phone}</a><div><small>STUDIO</small>{contact.address}</div></div></div><form class="contact-form" data-contact-form><label>Name<input required name="name" autocomplete="name" placeholder="Your name"/></label><label>Work email<input required type="email" name="email" autocomplete="email" placeholder="you@company.com"/></label><label>Phone / WhatsApp<input name="phone" autocomplete="tel" placeholder="+91 ..."/></label><label>What do you need?<select name="service"><option>Performance marketing</option><option>Personal branding</option><option>Social media growth</option><option>Website design & development</option><option>Growth consulting</option></select></label><label>Tell us about the project<textarea required name="message" rows="5" placeholder="Goals, challenges, timeline and approximate budget"></textarea></label><input class="hp-field" tabindex="-1" autocomplete="off" name="website" aria-hidden="true"/><button class="button button-light" type="submit">Send enquiry <span>↗</span></button><p class="contact-status" data-contact-status aria-live="polite"></p><small>Your enquiry is delivered securely to our Telegram workspace.</small></form></div></section><script is:inline src="/contact.js"></script></Base>
