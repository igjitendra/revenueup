---
import Base from '../layouts/Base.astro';import {contact} from '../data/site';
---
<Base title="Contact — RevenueUp"><section class="contact-page"><div class="container contact-grid"><div><span class="eyebrow light">START A CONVERSATION</span><h1>Tell us what<br/>you want to <em>grow.</em></h1><p>Share your goal, current challenge and timeline. We’ll reply with the most useful next step.</p><div class="contact-details"><a href={'mailto:'+contact.email}><small>EMAIL</small>{contact.email}</a><a href={'tel:'+contact.phone.replace(/ /g,'')}><small>PHONE / WHATSAPP</small>{contact.phone}</a><div><small>STUDIO</small>{contact.address}</div></div></div><form class="contact-form" action={'https://wa.me/'+contact.phoneRaw} method="get"><label>Name<input required name="name" placeholder="Your name"/></label><label>Work email<input required type="email" name="email" placeholder="you@company.com"/></label><label>What do you need?<select name="service"><option>Performance marketing</option><option>Personal branding</option><option>Social media growth</option><option>Website design & development</option><option>Growth consulting</option></select></label><label>Tell us about the project<textarea name="text" rows="5" placeholder="Goals, challenges, timeline and approximate budget"></textarea></label><button class="button button-light" type="submit">Send enquiry <span>↗</span></button><small>Submitting opens WhatsApp. No sensitive information, please.</small></form></div></section></Base>