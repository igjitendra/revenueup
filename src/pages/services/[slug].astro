---
import Base from '../../layouts/Base.astro';import CTA from '../../components/CTA.astro';import {services} from '../../data/site';
export function getStaticPaths(){return services.map(service=>({params:{slug:service.slug},props:{service}}))} const {service}=Astro.props;
---
<Base title={`${service.title} — RevenueUp`} description={service.short}><section class="page-hero service-detail"><div class="container"><a class="back" href="/services">← All services</a><div class="detail-grid"><div><span class="service-icon big">{service.icon}</span><span class="eyebrow">REVENUEUP SERVICE</span><h1>{service.title}</h1><p>{service.short}</p><a class="button" href="/contact">Request a proposal <span>↗</span></a></div><div class="scope-card"><small>TYPICAL SCOPE</small>{service.bullets.map((b,i)=><div><span>0{i+1}</span><b>{b}</b></div>)}</div></div></div></section><section class="section"><div class="container split"><div><span class="eyebrow">HOW IT WORKS</span><h2>Structured for<br/><em>momentum.</em></h2></div><div class="big-copy"><p>We begin with a focused audit, agree on success measures, then work in short cycles to ship, learn and improve.</p><div class="timeline"><div><b>01</b><span><strong>Audit & alignment</strong>Understand the current state and highest-leverage opportunities.</span></div><div><b>02</b><span><strong>Build & launch</strong>Create the system, assets and measurement foundation.</span></div><div><b>03</b><span><strong>Optimize & scale</strong>Use real data to improve quality and efficiency.</span></div></div></div></div></section><CTA/></Base>
