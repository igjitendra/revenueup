---
import '../styles/global.css';
import { contact } from '../data/site';
const {title='RevenueUp — Performance Marketing & Digital Growth', description='Performance marketing, personal branding, social media and conversion-first websites for ambitious businesses.', path=''} = Astro.props;
const canonical = new URL(path || Astro.url.pathname, Astro.site || Astro.url.origin);
---
<!doctype html><html lang="en"><head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>{title}</title><meta name="description" content={description}/><link rel="canonical" href={canonical}/>
<meta name="theme-color" content="#0b0d12"/><meta property="og:title" content={title}/><meta property="og:description" content={description}/><meta property="og:type" content="website"/>
<link rel="icon" href="/favicon.svg" type="image/svg+xml"/><script is:inline>document.documentElement.classList.add('js')</script>
</head><body>
<div class="progress" aria-hidden="true"></div>
<header class="nav-wrap"><div class="container nav"><a class="brand" href="/" aria-label="RevenueUp home"><span class="brand-mark">R</span><span>Revenue<span>Up</span></span></a>
<nav id="menu" aria-label="Main navigation"><a href="/services">Services</a><a href="/work">Work</a><a href="/about">About</a><a href="/pricing">Engagements</a><a href="/contact">Contact</a></nav>
<a class="button button-sm desktop-cta" href={'https://wa.me/'+contact.phoneRaw}>Start a project <span>↗</span></a><button class="menu-button" aria-controls="menu" aria-expanded="false" aria-label="Toggle menu"><i></i><i></i></button></div></header>
<main><slot /></main>
<footer><div class="container"><div class="footer-top"><div><a class="brand" href="/"><span class="brand-mark">R</span><span>Revenue<span>Up</span></span></a><p>Strategy, creative and technology—built around measurable growth.</p></div><div class="footer-links"><div><b>Explore</b><a href="/services">Services</a><a href="/work">Work</a><a href="/about">About</a></div><div><b>Connect</b><a href={'tel:'+contact.phone.replace(/ /g,'')}>{contact.phone}</a><a href={'mailto:'+contact.email}>{contact.email}</a><a href="https://www.instagram.com/revenueup.in/">Instagram</a></div><div><b>Legal</b><a href="/legal/privacy">Privacy</a><a href="/legal/terms">Terms</a><a href="/legal/refund">Refund policy</a></div></div></div><div class="footer-bottom"><span>© {new Date().getFullYear()} RevenueUp. All rights reserved.</span><span>Greater Noida · India</span></div></div></footer>
<a class="floating-wa" href={'https://wa.me/'+contact.phoneRaw} aria-label="Chat on WhatsApp">↗</a>
<script src="/site.js"></script>
</body></html>
